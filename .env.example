# Copy this file to .env (or export these as real environment variables)
# and fill in your own values. Never commit the real .env or token.txt file.

# Discord bot token — Discord Developer Portal > Applications > Bot
DISCORD_TOKEN=

# Groq API key used by the AI assistant (bot/ai_assistant.py)
GROQ_API_KEY=

# Serper.dev key used by the AI assistant's web search tool (bot/web_search.py)
SERPER_API_KEY=

# SerpApi key used by /news and /youtubevideo (bot/views/news_view.py, bot/views/youtube_view.py)
SERPAPI_KEY=
